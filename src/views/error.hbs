<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Error - Home Automation Dashboard</title>
    <link rel="stylesheet" href="/css/dashboard.css">
</head>
<body>
    <div class="dashboard-container">
        <div class="error-container" style="text-align: center; padding: 100px 20px;">
            <h1 style="font-size: 48px; color: #ef4444; margin-bottom: 20px;">⚠️</h1>
            <h2 style="font-size: 24px; color: #333; margin-bottom: 10px;">Error</h2>
            <p style="color: #666; margin-bottom: 30px;">{{message}}</p>
            <a href="/" class="btn btn-primary">Return to Dashboard</a>
        </div>
    </div>
</body>
</html>
